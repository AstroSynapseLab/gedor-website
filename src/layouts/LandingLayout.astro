---
// src/layouts/LandingLayout.astro
import '@/styles/global.css';
import type { PageMeta } from '@/lib/constants';
import { SITE_CONFIG } from '@/lib/constants';
import CookieBanner from '@/components/landing/CookieBanner.astro';

interface Props extends PageMeta {
  title?: string;
  description?: string;
}

const {
  title = 'Gedor.ai - EU AI Inference for Developers',
  description = 'Enterprise-grade AI inference built in Croatia for European developers. ISO 27001 & ISO 42001 certified.',
} = Astro.props as Props;
---

<!doctype html>
<html lang='en' class='dark' style='scroll-behavior:smooth'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta name='robots' content='index,follow' />
    <link rel='icon' type='image/png' href='/icon.png' />

    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link href='https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&display=swap' rel='stylesheet' />

    <!-- Force dark mode for landing page before paint -->
    <script is:inline>
      document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class='bg-background text-foreground overflow-x-hidden leading-[1.65] font-light antialiased'>
    <slot />
    <CookieBanner />
  </body>
</html>
