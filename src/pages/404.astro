---
import { IconArrowLeft } from '@tabler/icons-react';
import LandingLayout from '@/layouts/LandingLayout.astro';
import ParticlesCanvas from '@/components/landing/ParticlesCanvas.astro';
---

<LandingLayout
  title='404 - Page Not Found | Gedor.ai'
  description='Enterprise-grade AI inference built in Croatia for European developers. ISO 27001 & ISO 42001 certified. Code models, image recognition, full GDPR compliance.'
>
  <div class='landing-bg pointer-events-none fixed inset-0 z-0' aria-hidden='true'></div>

  <div class='landing-grain' aria-hidden='true'></div>

  <ParticlesCanvas />

  <section id='not-found' class='relative flex h-svh min-h-125 w-full items-center justify-center overflow-hidden'>
    <div
      class='pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-10%,rgba(160,109,212,0.06),transparent)]'
    >
    </div>
    <div
      id='not-found-glow'
      class='pointer-events-none absolute h-175 w-175 rounded-full opacity-0 transition-opacity duration-500'
    >
    </div>

    <div class='relative z-10 container px-6 text-center'>
      <h1
        class='font-display mb-3 text-[72px] leading-none font-bold tracking-tighter sm:text-[110px] md:mb-4 md:text-[240px]'
      >
        4<span
          class='from-primary via-secondary to-gedor-teal inline-block animate-[grad-shift_1.5s_ease-in-out_infinite_alternate] bg-linear-to-br bg-size-[200%] bg-clip-text text-transparent'
          >0</span
        >4
      </h1>

      <p class='text-foreground/60 mb-3 font-mono text-base tracking-wider uppercase md:text-xl'>Page not found</p>

      <p class='text-foreground/60 mx-auto mb-8 max-w-xs text-sm leading-[1.75] md:mb-10 md:max-w-100 md:text-base'>
        The page you are looking for does not exist or has been moved.
      </p>

      <a
        href='/'
        class='text-foreground/60 hover:text-foreground inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/3 px-5 py-3 font-mono text-sm no-underline backdrop-blur-sm transition-[color,border-color,background] duration-200 hover:border-white/20 hover:bg-white/6'
      >
        <IconArrowLeft size={14} stroke={1.5} />
        Go home
      </a>
    </div>
  </section>
</LandingLayout>

<style>
  #not-found-glow {
    background: radial-gradient(circle, rgba(160, 109, 212, 0.12) 0%, transparent 70%);
    will-change: transform;
  }
</style>

<script>
  const section = document.getElementById('not-found') as HTMLElement;
  const glow = document.getElementById('not-found-glow') as HTMLElement;
  const half = 350;

  function moveGlow(x: number, y: number) {
    const rect = section.getBoundingClientRect();
    glow.style.opacity = '1';
    glow.style.left = x - rect.left - half + 'px';
    glow.style.top = y - rect.top - half + 'px';
  }

  section.addEventListener('mousemove', e => moveGlow(e.clientX, e.clientY));
  section.addEventListener('mouseleave', () => {
    glow.style.opacity = '0';
  });

  section.addEventListener(
    'touchmove',
    e => {
      const t = e.touches[0];
      moveGlow(t.clientX, t.clientY);
    },
    { passive: true }
  );
  section.addEventListener('touchend', () => {
    glow.style.opacity = '0';
  });
</script>
