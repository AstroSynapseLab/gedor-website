---
// src/components/Head.astro
import { DEFAULT_PAGE_META, SEO_DEFAULTS, getDefaultPageMeta, SITE_CONFIG } from '@/lib/constants';
import type { PageMeta } from '@/lib/constants';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { LanguageEnum } from '@/types';

const props = Astro.props as PageMeta;

// EN is default
const locale = (Astro.currentLocale as LanguageEnum) ?? LanguageEnum.EN;

// Localized defaults (falls back to EN)
const defaults = getDefaultPageMeta(locale);

const {
  title = defaults.title ?? DEFAULT_PAGE_META.title,
  description = defaults.description ?? DEFAULT_PAGE_META.description,
  ogType = defaults.ogType ?? DEFAULT_PAGE_META.ogType,
  ogImage = defaults.ogImage ?? DEFAULT_PAGE_META.ogImage,
  noindex = false,
  nofollow = false,
} = props;

// Canonical + alternates generated by Astro i18n (respects i18n routing config)
const canonicalURL = getAbsoluteLocaleUrl(locale);
const alternateEn = getAbsoluteLocaleUrl(LanguageEnum.EN);
const alternateHr = getAbsoluteLocaleUrl(LanguageEnum.HR);

// OpenGraph locale mapping (pick whatever regions you prefer)
const ogLocaleMap: Record<LanguageEnum, string> = {
  [LanguageEnum.EN]: 'en_US',
  [LanguageEnum.HR]: 'hr_HR',
};

const ogImageURL = ogImage ? new URL(ogImage, Astro.site || SITE_CONFIG.url).href : null;
---

<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width,initial-scale=1.0,maximum-scale=5' />

  <title>{title} | {SITE_CONFIG.name}</title>
  <meta name='description' content={description} />

  <meta name='robots' content={`${noindex ? 'noindex' : 'index'},${nofollow ? 'nofollow' : 'follow'}`} />
  <meta name='generator' content={Astro.generator} />

  <link rel='canonical' href={canonicalURL} />
  <link rel='alternate' hreflang={LanguageEnum.EN} href={alternateEn} />
  <link rel='alternate' hreflang={LanguageEnum.HR} href={alternateHr} />
  <link rel='alternate' hreflang='x-default' href={alternateEn} />

  <!-- Security / performance -->
  <meta http-equiv='X-Content-Type-Options' content='nosniff' />
  <meta name='referrer' content='strict-origin-when-cross-origin' />
  <meta name='format-detection' content='telephone=no,address=no,email=no' />

  <!-- Open Graph -->
  <meta property='og:type' content={ogType} />
  <meta property='og:site_name' content={SITE_CONFIG.name} />
  <meta property='og:title' content={title} />
  <meta property='og:description' content={description} />
  <meta property='og:url' content={canonicalURL} />
  {ogImageURL && <meta property='og:image' content={ogImageURL} />}
  <meta property='og:locale' content={ogLocaleMap[locale]} />
  <meta
    property='og:locale:alternate'
    content={ogLocaleMap[locale === LanguageEnum.EN ? LanguageEnum.HR : LanguageEnum.EN]}
  />

  <!-- Twitter -->
  <meta name='twitter:card' content={SEO_DEFAULTS.twitterCard} />
  <meta name='twitter:title' content={title} />
  <meta name='twitter:description' content={description} />
  {ogImageURL && <meta name='twitter:image' content={ogImageURL} />}

  <!-- Icons -->
  <link rel='icon' type='image/png' href='/assets/common/images/favicon-96x96.png' sizes='96x96' />
  <link rel='icon' type='image/svg+xml' href='/assets/common/images/favicon.svg' />
  <link rel='shortcut icon' href='/assets/common/images/favicon.ico' />
  <link rel='apple-touch-icon' sizes='180x180' href='/assets/common/images/apple-touch-icon.png' />
  <meta name='apple-mobile-web-app-title' content='ArtIt Coding' />
  <link rel='manifest' href='/assets/common/images/site.webmanifest' />

  <slot />

  <script is:inline>
    (() => {
      const key = 'theme-preference';
      const root = document.documentElement;
      const mql = window.matchMedia('(prefers-color-scheme: dark)');

      const apply = mode => {
        root.classList.toggle('dark', mode === 'dark' || (mode === 'system' && mql.matches));
      };

      const stored = localStorage.getItem(key);
      const mode = stored === 'light' || stored === 'dark' || stored === 'system' ? stored : 'light';

      apply(mode);

      mql.addEventListener('change', e => {
        if (localStorage.getItem(key) === 'system') {
          root.classList.toggle('dark', e.matches);
        }
      });
    })();
  </script>
</head>
