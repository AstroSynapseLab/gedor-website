---
// src/components/landing/CookieBanner.astro
---

<div
  id='cookie-banner'
  role='dialog'
  aria-label='Cookie consent'
  class='pointer-events-none fixed right-0 bottom-6 left-0 z-50 container translate-y-4 opacity-0 transition-[opacity,transform] duration-500'
>
  <div
    class='border-primary/20 relative overflow-hidden rounded-2xl border bg-[rgba(6,6,16,0.82)] px-5 py-5 shadow-[0_8px_48px_rgba(0,0,0,0.7),inset_0_1px_0_rgba(255,255,255,0.09),0_0_35px_rgba(160,109,212,0.30),0_0_80px_rgba(160,109,212,0.12)] backdrop-blur-[32px]'
  >
    <div
      class='pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-white/15 to-transparent'
    >
    </div>

    <div class='relative flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-5'>
      <p class='text-foreground flex-1 text-base'>
        We use cookies to remember your preferences and improve your experience.
        <a
          href='/privacy-policy'
          class='text-primary/80 hover:text-primary underline underline-offset-2 transition-colors duration-150'
          >Privacy Policy</a
        >
      </p>

      <div class='flex shrink-0 items-center gap-2.5'>
        <button
          id='cookie-decline'
          class='text-foreground/50 hover:text-foreground/80 cursor-pointer rounded-lg border border-white/10 bg-white/4 px-4 py-2 font-mono text-sm backdrop-blur-sm transition-all duration-200 hover:border-white/20 hover:bg-white/7'
        >
          DECLINE
        </button>
        <button
          id='cookie-accept'
          class='from-primary to-secondary relative cursor-pointer rounded-lg bg-linear-to-br px-4 py-2 font-mono text-sm font-medium text-white shadow-[0_0_20px_rgba(160,109,212,0.25)] transition-all duration-200 hover:opacity-90 hover:shadow-[0_0_28px_rgba(160,109,212,0.4)]'
        >
          ACCEPT
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const COOKIE_NAME = 'gedor_cookie_consent';
  const COOKIE_MAX = 'Fri, 31 Dec 9999 23:59:59 GMT';

  function getCookie(name: string): string | null {
    const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
    return match ? decodeURIComponent(match[1]) : null;
  }

  function setCookie(name: string, value: string) {
    document.cookie = `${name}=${encodeURIComponent(value)}; expires=${COOKIE_MAX}; path=/; SameSite=Lax`;
  }

  const banner = document.getElementById('cookie-banner') as HTMLElement;

  function hideBanner() {
    banner.style.opacity = '0';
    banner.style.transform = 'translateY(16px)';
    banner.style.pointerEvents = 'none';
    setTimeout(() => {
      banner.style.display = 'none';
    }, 520);
  }

  function showBanner() {
    banner.style.display = '';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        banner.style.pointerEvents = 'auto';
        banner.style.opacity = '1';
        banner.style.transform = 'translateY(0)';
      });
    });
  }

  if (!getCookie(COOKIE_NAME)) {
    showBanner();
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    setCookie(COOKIE_NAME, 'accepted');
    hideBanner();
  });

  document.getElementById('cookie-decline')?.addEventListener('click', () => {
    setCookie(COOKIE_NAME, 'declined');
    hideBanner();
  });
</script>
