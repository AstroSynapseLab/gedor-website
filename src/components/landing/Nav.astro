---
// src/components/landing/Nav.astro
---

<nav id='site-nav' class='fixed top-0 right-0 left-0 z-100 px-8 py-3.5'>
  <div
    id='site-nav-inner'
    class='mx-auto flex h-13 max-w-280 items-center justify-between rounded-[14px] border border-transparent px-5 transition-[background,border-color,box-shadow,backdrop-filter] duration-300'
  >
    <a href='/' class='flex items-center gap-2.5 no-underline'>
      <img src='/assets/common/images/icon.png' alt='Gedor.ai icon' class='block h-6 w-auto' />
      <img src='/assets/common/images/logo-text.png' alt='Gedor.ai' class='block h-6 w-auto' />
    </a>

 
    <a
      href='#waitlist'
      id='nav-cta'
      class='rounded-lg border-0 bg-gedor-amber px-4.5 py-2 font-mono text-sm font-medium text-[#0d1b2a] no-underline transition-shadow duration-300 hover:shadow-[0_0_18px_rgba(37,99,235,0.18)]'
    >
      JOIN WAITLIST
    </a>
  </div>
</nav>

<style>
  #site-nav-inner.scrolled {
    background: rgba(232, 243, 255, 0.96);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border-color: rgba(37, 99, 235, 0.25);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 0 30px rgba(37, 99, 235, 0.08);
  }
</style>

<script>
  const navInner = document.getElementById('site-nav-inner');
  const onScroll = () => navInner?.classList.toggle('scrolled', window.scrollY > 10);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const navCta = document.getElementById('nav-cta');
  navCta?.addEventListener('click', e => {
    e.preventDefault();
    document.getElementById('waitlist')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(() => (document.getElementById('wl-email') as HTMLInputElement)?.focus({ preventScroll: true }), 750);
  });
</script>
