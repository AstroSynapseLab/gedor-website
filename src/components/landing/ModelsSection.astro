---
// src/components/landing/ModelsSection.astro
import { IconCode, IconEye, IconRoad } from '@tabler/icons-react';

const models = [
  {
    name: 'devstral-small-24b',
    label: 'CODE',
    Icon: IconCode,
    color: 'text-primary',
    bg: 'bg-primary/10',
    border: 'border-primary/15',
  },
  {
    name: 'qwen2.5-vl-7b-instruct',
    label: 'VISION',
    Icon: IconEye,
    color: 'text-gedor-amber',
    bg: 'bg-gedor-amber/[0.08]',
    border: 'border-gedor-amber/15',
  },
  {
    name: 'More models - shaped by waitlist feedback',
    label: 'ROADMAP',
    Icon: IconRoad,
    color: 'text-foreground/30',
    bg: 'bg-white/40',
    border: 'border-[rgba(14,30,60,0.06)]',
    soon: true,
  },
] as const;
---

<section id='models' class='relative z-2 my-12 md:mt-36 md:mb-12'>
  <span
    class='reveal from-primary via-secondary to-gedor-teal mb-2 block animate-[grad-shift_1.5s_ease-in-out_infinite_alternate] bg-linear-to-br bg-size-[200%] bg-clip-text text-center font-mono text-2xl tracking-wider text-transparent uppercase md:mb-6'
  >
    Alpha Model Catalog
  </span>
  <h2
    class='reveal reveal-delay-1 font-display mb-2 text-center text-[30px] leading-8 font-bold md:mb-6 md:text-[46px] md:leading-10'
  >
    Two models. Both best-in-class.<br />More on the roadmap.
  </h2>
  <p class='reveal reveal-delay-2 text-foreground mx-auto mb-10 max-w-130 text-center text-base leading-[1.75]'>
    We launched with quality over quantity. Devstral for code, Qwen2.5-VL for vision - both on dedicated EU hardware.
    Tell us what you need next.
  </p>

  <div class='container mx-auto flex max-w-175 flex-col gap-1'>
    {
      models.map((m, i) => (
        <div
          class:list={[
            'reveal flex items-center justify-between px-5 py-4',
            'rounded-lg border border-[rgba(14,30,60,0.1)] bg-white/72 font-mono text-sm backdrop-blur-md',
            'shadow-[0_1px_6px_rgba(0,0,0,0.05),inset_0_1px_0_rgba(255,255,255,0.9)]',
            'cursor-default transition-[border-color,background,transform] duration-200',
            i === 2 ? 'opacity-50' : 'hover:border-primary/20 hover:bg-primary/4 hover:translate-x-1',
            i === 1 && 'reveal-delay-1',
            i === 2 && 'reveal-delay-2',
          ]}
        >
          <span class='text-foreground'>{m.name}</span>
          <span
            class:list={[
              'flex flex-row items-center gap-1 rounded border px-2.25 py-1 text-[9px] font-medium tracking-widest',
              m.color,
              m.bg,
              m.border,
            ]}
          >
            <m.Icon size={11} stroke={2} />
            {m.label}
          </span>
        </div>
      ))
    }
  </div>
</section>
