---
// src/components/landing/FeaturesSection.astro
import { IconBolt, IconCode, IconCurrencyEuro, IconEye, IconPlugConnected, IconShieldLock } from '@tabler/icons-react';

const features = [
  {
    Icon: IconShieldLock,
    iconColor: '#3b82f6',
    title: 'EU Data Sovereignty',
    desc: 'All infrastructure is owned and operated in Croatia. No CLOUD Act exposure, no third-country data transfers, no US hyperscaler in the chain.',
  },
  {
    Icon: IconBolt,
    iconColor: '#fbbf24',
    title: 'RTX Pro 6000 Blackwell',
    desc: 'Running on the RTX 6000 Blackwell - purpose-built for high-throughput inference. Models run in isolated instances, keeping latency predictable under concurrent load.',
  },
  {
    Icon: IconPlugConnected,
    iconColor: '#34d399',
    title: 'Drop-in OpenAI API',
    desc: 'Powered by LiteLLM. Change one line - swap <code class="font-mono text-[11px] text-primary">base_url</code> and you\'re on EU infrastructure. Streaming, function calling, and API key management included.',
    rawDesc: true,
  },
  {
    Icon: IconCode,
    iconColor: '#60a5fa',
    title: 'Devstral Small 24B',
    desc: "Mistral's state-of-the-art code model. Built for agentic coding, repo-level reasoning, and multi-file edits - not just autocomplete.",
  },
  {
    Icon: IconEye,
    iconColor: '#f87171',
    title: 'Qwen2.5-VL 7B',
    desc: 'Multimodal vision-language inference for screenshot analysis, diagram parsing, UI understanding, and document extraction - optimised for low latency.',
  },
  {
    Icon: IconCurrencyEuro,
    iconColor: '#2dd4bf',
    title: 'Transparent Pricing',
    desc: 'Usage-based, no minimums, no hidden fees. Roughly €6 per million input tokens, €18.50 per million output tokens. Pay for what you use, see exactly where it goes.',
  },
];
---

<section id='features' class='relative z-2 my-12 md:mt-36 md:mb-12'>
  <div class='container max-w-280'>
    <span
      class='reveal from-primary via-secondary to-gedor-teal mb-2 block animate-[grad-shift_1.5s_ease-in-out_infinite_alternate] bg-linear-to-br bg-size-[200%] bg-clip-text text-center font-mono text-2xl tracking-wider text-transparent uppercase md:mb-6'
    >
      Why Gedor.ai
    </span>
    <h2
      class='reveal reveal-delay-1 font-display mb-2 text-center text-[30px] leading-8 font-bold md:mb-6 md:text-[46px] md:leading-10'
    >
      No hyperscaler. No US jurisdiction.<br />No compromises.
    </h2>
    <p class='reveal reveal-delay-2 text-foreground mx-auto mb-10 max-w-130 text-center text-base leading-[1.75]'>
      Every token is processed on dedicated hardware in Croatia. Not resold cloud, not shared infrastructure - owned
      metal, full control.
    </p>

    <div class='grid grid-cols-3 gap-3 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1'>
      {
        features.map((f, i) => {
          const delayClass = i % 3 === 1 ? 'reveal-delay-1' : i % 3 === 2 ? 'reveal-delay-2' : '';
          return (
            <div class:list={['shimmer reveal feature-card', delayClass]}>
              <div class='absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[rgba(14,30,60,0.08)] to-transparent' />
              <div class='feature-glow pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgba(37,99,235,0.06),transparent_60%)] opacity-0 transition-opacity duration-400' />

              <div class='feature-icon mb-4.5 flex h-11 w-11 items-center justify-center rounded-[10px] border border-[rgba(14,30,60,0.1)] bg-white/80 shadow-[0_1px_4px_rgba(0,0,0,0.06)] backdrop-blur-sm transition-transform duration-300'>
                <f.Icon size={22} stroke={1.5} style={{ color: f.iconColor }} />
              </div>
              <div class='font-display mb-2.5 text-base font-bold tracking-[-0.3px]'>{f.title}</div>
              {f.rawDesc ? (
                <p class='text-muted-foreground text-sm leading-[1.65]' set:html={f.desc} />
              ) : (
                <p class='text-muted-foreground text-sm leading-[1.65]'>{f.desc}</p>
              )}
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .feature-card {
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(14, 30, 60, 0.1);
    border-radius: 16px;
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
    cursor: default;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.9);
    transition:
      transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.3s,
      box-shadow 0.3s;
  }
  .feature-card:hover {
    transform: translateY(-4px);
    border-color: rgba(37, 99, 235, 0.3);
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }
  .feature-card:hover .feature-glow {
    opacity: 1;
  }
  .feature-card:hover .feature-icon {
    transform: scale(1.1) rotate(-3deg);
  }
</style>
