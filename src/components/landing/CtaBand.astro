---
// src/components/landing/CtaBand.astro
interface Props {
  devFrom?: number;
  devTo?: number;
}
const { devFrom = 50, devTo = 150 } = Astro.props;
---

<section class='relative z-2 py-10 text-center md:py-25'>
  <div class='mx-auto max-w-280 px-8'>
    <div
      id='cta-band-card'
      class='reveal relative overflow-hidden rounded-3xl border border-[rgba(14,30,60,0.1)] bg-white/72 px-15 py-18 shadow-[0_8px_40px_rgba(0,0,0,0.07),inset_0_1px_0_rgba(255,255,255,0.95)] backdrop-blur-[48px] max-sm:px-6 max-sm:py-12'
    >
      <div class='cta-ambient-glow'></div>
      <div class='cta-mouse-glow'></div>

      <h2
        class='font-display relative mb-6 text-center text-[30px] leading-8 font-bold tracking-tighter md:text-[46px] md:leading-12'
      >
        Invite - only alpha.<br />{devFrom} - {devTo} developers.
      </h2>
      <p class='relative mx-auto mb-10 text-base leading-[1.75] text-[#4b6580]'>
        We're starting small and deliberate. <br />
        Request access - we'll onboard in waves, starting with the people who shape what we build.
      </p>

      <div class='relative flex justify-center'>
        <a
          href='#waitlist'
          id='cta-join'
          class='rounded-lg border-0 bg-gedor-amber px-4.5 py-2 font-mono text-sm font-medium text-[#0d1b2a] no-underline transition-shadow duration-300 hover:shadow-[0_0_18px_rgba(37,99,235,0.18)]'
        >
          <span class='pointer-events-none absolute inset-0 rounded-lg bg-linear-to-b from-white/20 to-transparent'></span>
          JOIN THE WAITLIST
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-ambient-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 100%, rgba(37, 99, 235, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-mouse-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.05) 0%, transparent 70%);
    transform: translate(calc(var(--mx, -999px) - 250px), calc(var(--my, -999px) - 250px));
    pointer-events: none;
    transition: transform 0.04s linear;
    will-change: transform;
  }
</style>

<script>
  const card = document.getElementById('cta-band-card') as HTMLElement | null;
  card?.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    card.style.setProperty('--mx', e.clientX - rect.left + 'px');
    card.style.setProperty('--my', e.clientY - rect.top + 'px');
  });
  card?.addEventListener('mouseleave', () => {
    card.style.setProperty('--mx', '-999px');
    card.style.setProperty('--my', '-999px');
  });

  document.getElementById('cta-join')?.addEventListener('click', e => {
    e.preventDefault();
    document.getElementById('waitlist')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(() => (document.getElementById('wl-email') as HTMLInputElement)?.focus({ preventScroll: true }), 750);
  });
</script>
