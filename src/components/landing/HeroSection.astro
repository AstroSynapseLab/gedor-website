---
// src/components/landing/HeroSection.astro
import { IconBolt, IconCertificate, IconFlag, IconPlugConnected, IconRobot, IconShieldLock } from '@tabler/icons-react';
import WaitlistForm from './WaitlistForm';

const TRUST_BADGES = [
  { Icon: IconShieldLock, label: 'ISO 27001', color: '#a06dd4' },
  { Icon: IconRobot, label: 'ISO 42001', color: '#2dd4bf' },
  { Icon: IconCertificate, label: 'GDPR Compliant', color: '#60a5fa' },
  { Icon: IconFlag, label: 'Hosted in Croatia', color: '#f87171' },
  { Icon: IconBolt, label: 'EU Low Latency', color: '#fbbf24' },
  { Icon: IconPlugConnected, label: 'OpenAI-Compatible API', color: '#34d399' },
] as const;
---

<div class='relative z-2 container max-w-7xl'>
  <section class='relative mt-36 text-center'>
    <div
      class='pointer-events-none absolute h-225 w-225 rounded-full border border-[rgba(160,109,212,0.08)]'
      style='top:50%;left:50%;animation:ring-spin 50s linear infinite;'
      aria-hidden='true'
    >
      <div
        class='absolute rounded-full border border-[rgba(177,65,149,0.06)]'
        style='inset:80px;animation:ring-spin-inner 35s linear infinite reverse;'
      >
      </div>
      <div
        class='absolute rounded-full border border-dashed border-[rgba(45,212,191,0.03)]'
        style='inset:170px;animation:ring-spin-inner 22s linear infinite;'
      >
      </div>
    </div>

    <h1 class='mx-auto mb-10 max-w-200 animate-[fadeUp_0.7s_ease_both] text-[4rem] leading-16 font-extrabold'>
      Private AI inference. <br />
      <span
        class='from-primary via-secondary to-gedor-teal animate-[grad-shift_1.5s_ease-in-out_infinite_alternate] bg-linear-to-br bg-size-[200%] bg-clip-text text-transparent'
      >
        Built in Europe. <br /> Stays in Europe.
      </span>
    </h1>

    <p class='mx-auto mb-10 max-w-140 animate-[fadeUp_0.7s_0.15s_ease_both] text-lg text-[#b8b8d8]'>
      A single OpenAI-compatible endpoint for code generation and vision, running on
      <strong class='text-foreground font-bold'>dedicated EU hardware</strong>
      in Croatia. Your prompts, your data, your models. <strong class='text-foreground font-bold'
        >Never on a US cloud.</strong
      >
    </p>

    <div id='waitlist' class='mx-auto max-w-180 animate-[fadeUp_0.7s_0.28s_ease_both]'>
      <WaitlistForm client:load />
    </div>

    <div
      class='border-border mt-16 flex animate-[fadeUp_0.7s_0.42s_ease_both] flex-wrap items-center justify-center gap-2 border-t pt-16'
    >
      {
        TRUST_BADGES.map(({ Icon, label, color }) => (
          <div class='hover:border-primary/30 hover:bg-primary/6 flex cursor-default items-center gap-1.5 rounded-lg border border-white/12 bg-white/6 px-3.5 py-2 font-mono text-sm text-[#b0b0cc] shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] backdrop-blur-sm transition-[border-color,background,transform] duration-200 hover:-translate-y-0.5'>
            <Icon size={18} stroke={1} style={{ color }} className='shrink-0' />
            {label}
          </div>
        ))
      }
    </div>
  </section>
</div>
