---
import { getRelativeLocaleUrl } from 'astro:i18n';

import { useTranslation } from '@/i18n';
import { LanguageEnum } from '@/types';

const locales = [LanguageEnum.EN, LanguageEnum.HR];
const current = (Astro.currentLocale as LanguageEnum) ?? LanguageEnum.EN;
const t = useTranslation(current);

const neutralPath = Astro.url.pathname.replace(
  new RegExp(`^/(${locales.join('|')})(?=/|$)`),
  ''
);
---

<nav class='lang-switcher' aria-label='Language'>
  {
    locales.map(locale => (
      <a
        href={getRelativeLocaleUrl(locale, neutralPath)}
        aria-current={locale === current ? 'true' : undefined}
        class:list={['lang-link', { active: locale === current }]}
      >
        {t(`langs.${locale}` as `langs.${LanguageEnum}`)}
      </a>
    ))
  }
</nav>

<style lang='scss'>
  .lang-switcher {
    display: inline-flex;
    gap: 0.5rem;
  }

  .lang-link {
    text-decoration: none;
    color: inherit;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;

    &.active {
      font-weight: 600;
      text-decoration: underline;
    }

    &:hover {
      background-color: rgba(0, 0, 0, 0.05);
    }
  }
</style>
