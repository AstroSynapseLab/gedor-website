{
  "name": "gedor-website",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.1.0"
  },
  "volta": {
    "node": "24.4.1",
    "npm": "10.8.2"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development astro dev --mode development",
    "start": "astro dev",
    "build": "astro build && npm run format-html",
    "format-html": "prettier --write \"dist/**/*.html\"",
    "preview": "astro preview",
    "astro": "astro",
    "stg": "cross-env NODE_ENV=staging astro build --mode staging",
    "prod": "cross-env NODE_ENV=production astro build --mode production",
    "lint": "eslint . --ext .js,.mjs,.ts,.jsx,.tsx,.astro",
    "lint:fix": "eslint . --ext .js,.mjs,.ts,.jsx,.tsx,.astro --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aikidosec/safe-chain": "^1.0.24",
    "@astrojs/react": "^4.4.0",
    "@astrojs/vercel": "^9.0.4",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter-tight": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tabler/icons-react": "^3.36.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "astro": "^5.14.1",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "resend": "^6.9.1",
    "sass-embedded": "^1.93.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "vaul": "^1.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.6.2",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "fast-glob": "^3.3.3",
    "globals": "^17.3.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tw-animate-css": "^1.4.0"
  }
}
